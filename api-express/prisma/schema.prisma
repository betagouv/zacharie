// Modification d'une carcasse demandée par un intermédiaire, approuvée ou refusée par l'examinateur initial.
// Deux types :
//   - BRACELET_RENAME : le numéro de marquage sur la fiche ne correspond pas au numéro physique
//   - NEW_CARCASSE    : une carcasse physique manque dans la fiche ; l'intermédiaire pré-remplit, l'examinateur signe l'examen
enum CarcasseModificationRequestType {
  BRACELET_RENAME
  NEW_CARCASSE
}

enum CarcasseModificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CarcasseModificationRequest {
  id                     String                            @id @default(uuid())
  type                   CarcasseModificationRequestType
  status                 CarcasseModificationRequestStatus @default(PENDING)
  zacharie_carcasse_id   String
  fei_numero             String
  requested_by_user_id   String
  requested_by_entity_id String
  requested_at           DateTime                          @default(now())
  comment_intermediaire  String?
  // RENAME-specific
  numero_bracelet_before String?
  numero_bracelet_after  String?
  // review
  reviewed_by_user_id    String?
  reviewed_at            DateTime?
  rejection_reason       String?
  // tech
  created_at             DateTime                          @default(now())
  updated_at             DateTime                          @default(now()) @updatedAt
  deleted_at             DateTime?
  is_synced              Boolean                           @default(true)

  Carcasse          Carcasse @relation("CarcasseModificationRequestCarcasse", fields: [zacharie_carcasse_id], references: [zacharie_carcasse_id], onDelete: Cascade, onUpdate: Cascade)
  RequestedByUser   User     @relation("ModifRequestedByUser", fields: [requested_by_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  RequestedByEntity Entity   @relation("ModifRequestedByEntity", fields: [requested_by_entity_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ReviewedByUser    User?    @relation("ModifReviewedByUser", fields: [reviewed_by_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // Unicité "un seul PENDING par carcasse" : à ajouter manuellement dans la migration via SQL
  // (Prisma ne supporte pas les index uniques partiels) :
  //   CREATE UNIQUE INDEX "carcasse_one_pending_request"
  //   ON "CarcasseModificationRequest" (zacharie_carcasse_id)
  //   WHERE status = 'PENDING' AND deleted_at IS NULL;

  @@index([zacharie_carcasse_id])
  @@index([reviewed_by_user_id, status])
}

// =====================================================================
// TRICHINE
// Traçabilité des analyses trichine pour les sangliers (cf doc/trichine.md).
// Circuit court (1er détenteur) + circuit agréé (SVI en ETG).
// Note typage : seuls les enums réglementaires stricts sont typés.
// Les valeurs UX (statuts UI, types document/notif, objet polymorphique)
// sont des String pour permettre l'itération sans migration.
// =====================================================================

// Type partagé Échantillon + Pool (mêmes valeurs réglementaires)
enum TrichineType {
  INITIAL
  COMPLEMENTAIRE
  CONFIRMATION
}

// Statut analytique partagé Échantillon / Pool / FTP
enum TrichineStatutAnalyse {
  A_COMPLETER
  EN_COURS_ANALYSES
  ANALYSES_TERMINEES
}

enum TrichineSitePrelevement {
  PILIER_DIAPHRAGME
  LANGUE
  MEMBRE_ANTERIEUR
}

enum TrichineStatutLogistiqueFTP {
  BROUILLON
  ENVOYEE
  RECUE
  TRAITEE
}

enum TrichineResultatAnalyse {
  NEGATIF // LVD : pas de larve, carcasses du pool acceptées
  DOUTEUX // LVD : larve détectée, confirmation LNR obligatoire + 2e intention optionnelle
  ANALYSE_IMPOSSIBLE // LVD : refus / pool non analysable
  NON_NEGATIF // LNR : autre parasite identifié (parasite_identifie rempli)
  PRESENCE_PARASITE_NON_IDENTIFIE // LNR : larve présente mais non identifiée
  POSITIF // LNR : trichine confirmée
}

model TrichineEchantillon {
  id                    String   @id @default(uuid())
  reference_echantillon String   @unique // format E-{YY}-{séquence}, ex: E-26-000123
  zacharie_carcasse_id  String
  Carcasse              Carcasse @relation(fields: [zacharie_carcasse_id], references: [zacharie_carcasse_id], onDelete: Cascade, onUpdate: Cascade)

  preleve_par_user_id   String
  PreleveParUser        User    @relation("TrichineEchantillonPreleveParUser", fields: [preleve_par_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // Entity SVI en circuit agréé (PAS l'ETG) ou Entity PD en circuit court
  preleve_par_entity_id String?
  PreleveParEntity      Entity? @relation("TrichineEchantillonPreleveParEntity", fields: [preleve_par_entity_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  type             TrichineType
  site_prelevement TrichineSitePrelevement
  masse_grammes    Int // 5 (initial), 20 (mini-pool fille) ou 50 (individuel petite-fille)
  date_prelevement DateTime                @db.Date

  statut           TrichineStatutAnalyse    @default(A_COMPLETER)
  resultat_analyse TrichineResultatAnalyse? // cache hérité du pool

  pool_id      String?
  TrichinePool TrichinePool? @relation(fields: [pool_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  commentaire String?

  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  is_synced  Boolean   @default(true)

  @@index([zacharie_carcasse_id])
  @@index([pool_id])
  @@index([updated_at])
}

model TrichinePool {
  id             String @id @default(uuid())
  reference_pool String @unique // format P-{YY}-{séquence}, ex: P-26-000045

  cree_par_user_id   String
  CreeParUser        User    @relation("TrichinePoolCreeParUser", fields: [cree_par_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cree_par_entity_id String?
  CreeParEntity      Entity? @relation("TrichinePoolCreeParEntity", fields: [cree_par_entity_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  type TrichineType

  // Hiérarchie mère / fille / petite-fille
  pool_parent_id String?
  PoolParent     TrichinePool?  @relation("TrichinePoolHierarchy", fields: [pool_parent_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  PoolsFilles    TrichinePool[] @relation("TrichinePoolHierarchy")

  date_constitution  DateTime  @db.Date
  date_reception     DateTime? // saisie par LVD/LNR à réception
  date_debut_analyse DateTime? @db.Date
  date_fin_analyse   DateTime? @db.Date

  statut             TrichineStatutAnalyse    @default(A_COMPLETER)
  resultat_analyse   TrichineResultatAnalyse?
  parasite_identifie String? // rempli si NON_NEGATIF par LNR
  reference_labo     String? // n° interne attribué par le labo à réception

  refus_par_user_id String?
  RefusParUser      User?   @relation("TrichinePoolRefusParUser", fields: [refus_par_user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  raison_refus      String?

  commentaire String?

  TrichineEchantillons TrichineEchantillon[]
  TrichinePoolFTPs     TrichinePoolFTP[]
  Documents            TrichineDocument[]

  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  is_synced  Boolean   @default(true)

  @@index([pool_parent_id])
  @@index([cree_par_user_id])
  @@index([cree_par_entity_id])
  @@index([updated_at])
}

model TrichineFTP {
  id            String    @id @default(uuid())
  numero_fiche  String    @unique // format F-{YY}-{séquence}, ex: F-26-000012
  date_creation DateTime  @default(now())
  date_envoi    DateTime?

  expediteur_user_id   String
  ExpediteurUser       User    @relation("TrichineFTPExpediteurUser", fields: [expediteur_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expediteur_entity_id String?
  ExpediteurEntity     Entity? @relation("TrichineFTPExpediteurEntity", fields: [expediteur_entity_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Entity LABORATOIRE destinataire (LVD ou LNR selon is_lnr)
  destinataire_entity_id String
  DestinataireEntity     Entity @relation("TrichineFTPDestinataireEntity", fields: [destinataire_entity_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Hiérarchie : FTP LVD → LNR référence la FTP émettrice initiale
  ftp_parent_id String?
  FTPParent     TrichineFTP?  @relation("TrichineFTPHierarchy", fields: [ftp_parent_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  FTPChildren   TrichineFTP[] @relation("TrichineFTPHierarchy")

  statut_logistique TrichineStatutLogistiqueFTP @default(BROUILLON)
  statut_analytique TrichineStatutAnalyse       @default(A_COMPLETER)

  mode_transport String?
  commentaire    String?

  TrichinePoolFTPs TrichinePoolFTP[]
  Documents        TrichineDocument[]

  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  is_synced  Boolean   @default(true)

  @@index([expediteur_user_id])
  @@index([destinataire_entity_id])
  @@index([ftp_parent_id])
  @@index([updated_at])
}

// Jointure : un pool peut être référencé dans 2 FTP successives (LVD puis LNR)
model TrichinePoolFTP {
  id         String   @id @default(uuid())
  pool_id    String
  ftp_id     String
  date_ajout DateTime @default(now())

  TrichinePool TrichinePool @relation(fields: [pool_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  TrichineFTP  TrichineFTP  @relation(fields: [ftp_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([pool_id, ftp_id])
  @@index([ftp_id])
}

// Document attaché soit à un pool, soit à une FTP (jamais les deux en même temps).
// Type non typé strictement (String) : "RAPPORT_COFRAC" / "PHOTOGRAPHIE_LARVE" / "FTP_PDF" / "AUTRE" / ...
model TrichineDocument {
  id                 String   @id @default(uuid())
  type               String
  fichier_url        String // clé S3/Cellar
  date_ajout         DateTime @default(now())
  ajoute_par_user_id String
  AjouteParUser      User     @relation("TrichineDocumentAjouteParUser", fields: [ajoute_par_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  pool_id      String?
  TrichinePool TrichinePool? @relation(fields: [pool_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  ftp_id       String?
  TrichineFTP  TrichineFTP?  @relation(fields: [ftp_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  is_synced  Boolean   @default(true)

  @@index([pool_id])
  @@index([ftp_id])
}

// Notification polymorphique. type/objet_type sont String pour permettre l'évolution UX.
// type : "RESULTAT_ANALYSE" | "FTP_RECUE" | "POOL_REFUSE" | "CHANGEMENT_STATUT" | ...
// objet_type : "CARCASSE" | "ECHANTILLON" | "POOL" | "FTP" | ...
model TrichineNotification {
  id             String    @id @default(uuid())
  utilisateur_id String
  Utilisateur    User      @relation("TrichineNotificationUtilisateur", fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type           String
  objet_type     String
  objet_id       String
  message        String
  date_creation  DateTime  @default(now())
  lu             Boolean   @default(false)
  date_lecture   DateTime?

  @@index([utilisateur_id, lu])
  @@index([objet_type, objet_id])
}

// Historique d'audit polymorphique des changements de statut.
model TrichineHistoriqueStatut {
  id                  String   @id @default(uuid())
  objet_type          String // CARCASSE / ECHANTILLON / POOL / FTP / ...
  objet_id            String
  ancien_statut       String
  nouveau_statut      String
  date_changement     DateTime @default(now())
  modifie_par_user_id String
  ModifieParUser      User     @relation("TrichineHistoriqueModifieParUser", fields: [modifie_par_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  commentaire         String?

  @@index([objet_type, objet_id])
  @@index([modifie_par_user_id])
}
