enum ApiKeyScope {
  FEI_READ_FOR_USER
  FEI_READ_FOR_ENTITY
  CARCASSE_READ_FOR_USER
  CARCASSE_READ_FOR_ENTITY
}

model ApiKey {
  id                     String        @id @default(uuid())
  private_key            String        @unique
  public_key             String        @unique
  dedicated_to_entity_id String?
  name                   String
  slug_for_context       String?
  description            String? // Purpose of the API key
  webhook_url            String? // Webhook URL for the API key
  active                 Boolean       @default(true)
  expires_at             DateTime? // Optional expiration date
  last_used_at           DateTime? // Track when the key was last used
  access_token           String?       @unique
  access_token_read_at   DateTime?
  scopes                 ApiKeyScope[] // Array of permissions/scopes
  rate_limit             Int? // Requests per minute/hour allowed
  created_at             DateTime      @default(now())
  updated_at             DateTime      @default(now()) @updatedAt
  deleted_at             DateTime? // Soft delete support

  // Relations
  approvals ApiKeyApprovalByUserOrEntity[]
  logs      ApiKeyLog[]
  Entity    Entity?                        @relation("EntityRelatedWithApiKey", fields: [dedicated_to_entity_id], references: [id], onDelete: Cascade)

  @@index([active, expires_at]) // For checking valid keys
  @@index([last_used_at]) // For cleanup of unused keys
}

enum ApiKeyApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApiKeyApprovalByUserOrEntity {
  id                      String               @id @default(uuid())
  api_key_id              String
  user_id                 String?
  entity_id               String?
  status                  ApiKeyApprovalStatus
  access_token            String?              @unique
  access_token_created_at DateTime?
  created_at              DateTime             @default(now())
  updated_at              DateTime             @default(now()) @updatedAt

  // Relations
  ApiKey ApiKey  @relation(fields: [api_key_id], references: [id], onDelete: Cascade)
  User   User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Entity Entity? @relation(fields: [entity_id], references: [id], onDelete: Cascade)

  @@unique([api_key_id, entity_id])
  @@unique([api_key_id, user_id])
  @@index([api_key_id, status])
  @@index([user_id, status])
  @@index([entity_id, status])
}

enum ApiKeyLogAction {
  CREATED // When the API key is first created
  USED // When the API key is used to make a request
  WEBHOOK_SENT // When the API key is used to send a webhook
  REVOKED // When the API key is manually deactivated
  EXPIRED // When the API key reaches its expiration date
  UPDATED // When the API key details are modified
  RATE_LIMITED // When a request is blocked due to rate limiting
  INVALID_SCOPE // When a request is blocked due to insufficient permissions
}

model ApiKeyLog {
