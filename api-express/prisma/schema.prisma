  svi_closed_by_user_id                                   String?
  // Ownership (copied from FEI for carcasse-level ownership tracking)
  // Current Owner
  current_owner_user_id                                   String?
  current_owner_user_name_cache                           String?
  current_owner_entity_id                                 String?
  current_owner_entity_name_cache                         String?
  current_owner_role                                      FeiOwnerRole?
  // Next Owner
  next_owner_wants_to_sous_traite                         Boolean?
  next_owner_sous_traite_at                               DateTime?
  next_owner_sous_traite_by_user_id                       String?
  next_owner_sous_traite_by_entity_id                     String?
  next_owner_user_id                                      String?
  next_owner_user_name_cache                              String?
  next_owner_entity_id                                    String?
  next_owner_entity_name_cache                            String?
  next_owner_role                                         FeiOwnerRole?
  // Previous Owner
  prev_owner_user_id                                      String?
  prev_owner_entity_id                                    String?
  prev_owner_role                                         FeiOwnerRole?
  // technical fields
  created_at                                              DateTime                      @default(now())
  updated_at                                              DateTime                      @default(now()) @updatedAt
  deleted_at                                              DateTime?
  is_synced                                               Boolean                       @default(true)
  Fei                                                     Fei                           @relation(fields: [fei_numero], references: [numero], onDelete: Cascade, onUpdate: Cascade)
  CarcasseIntermediaire                                   CarcasseIntermediaire[]
  SviIpm1User                                             User?                         @relation("SviIpm1User", fields: [svi_ipm1_user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  CarcasseCertificats                                     CarcasseCertificat[]
  CarcasseSviEntity                                       Entity?                       @relation("CarcasseSviEntity", fields: [svi_entity_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  CarcasseModificationRequests                            CarcasseModificationRequest[] @relation("CarcasseModificationRequestCarcasse")
  // Trichine
  TrichineRetireDeFeiUser                                 User?                         @relation("CarcasseTrichineRetireDeFeiUser", fields: [trichine_retire_de_fei_user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  TrichineEchantillons                                    TrichineEchantillon[]

  @@index([fei_numero, numero_bracelet])
  @@index([deleted_at, date_mise_a_mort, numero_bracelet(sort: Desc)])
  @@index([deleted_at, created_at])
  @@index([numero_bracelet])
  @@index([deleted_at, updated_at])
  @@index([intermediaire_carcasse_refus_intermediaire_id])
  @@index([intermediaire_carcasse_manquante])
  // Colonnes de propriété utilisées dans le OR de GET /carcasse (cf carcasse.ts).
  // Composite avec updated_at desc : sert le filtre d'égalité (bitmap OR du full sync),
  // la range delta-sync (col = X AND updated_at >= after) et l'orderBy updated_at desc.
  @@index([svi_entity_id, updated_at(sort: Desc)])
  @@index([next_owner_entity_id, updated_at(sort: Desc)])
  @@index([current_owner_entity_id, updated_at(sort: Desc)])
  @@index([premier_detenteur_entity_id, updated_at(sort: Desc)])
  @@index([prev_owner_entity_id, updated_at(sort: Desc)])
  @@index([premier_detenteur_user_id, updated_at(sort: Desc)])
  @@index([examinateur_initial_user_id, updated_at(sort: Desc)])
  @@index([current_owner_user_id, updated_at(sort: Desc)])
  @@index([next_owner_user_id, updated_at(sort: Desc)])
  @@index([prev_owner_user_id, updated_at(sort: Desc)])
}

